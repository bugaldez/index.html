
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atlas Morfológico Interactivo · Hematología</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --rojo: #993C1D;
      --rojo-medio: #D85A30;
      --rojo-claro: #F5C4B3;
      --rojo-palido: #FAECE7;
      --fondo: #ffffff;
      --fondo2: #F8F6F5;
      --borde: #E8E0DC;
      --texto: #1a0f0a;
      --texto-suave: #6b5a52;
    }

    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--fondo); color: var(--texto); min-height: 100vh; }

    /* HERO */
    .hero {
      background: linear-gradient(135deg, #7A2900 0%, #993C1D 50%, #B84A22 100%);
      padding: 40px 48px 36px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 24px;
    }

    .hero-left .pretitulo { font-size: 11px; color: var(--rojo-claro); font-weight: 500; text-transform: uppercase; letter-spacing: .1em; margin-bottom: 10px; }
    .hero-left .titulo { font-size: 52px; font-weight: 500; color: #fff; line-height: 1; margin-bottom: 8px; }
    .hero-left .titulo span { color: var(--rojo-claro); }
    .hero-left .subtitulo { font-size: 14px; color: #F0997B; margin-bottom: 4px; }
    .hero-left .institucion { font-size: 12px; color: rgba(255,255,255,.6); }
    .hero-right { text-align: right; }
    .hero-right .universidad { font-size: 13px; color: var(--rojo-claro); font-weight: 500; }
    .hero-right .docente { font-size: 11px; color: rgba(255,255,255,.5); margin-top: 3px; }

    .hero-stats { display: flex; gap: 12px; margin-top: 12px; justify-content: flex-end; }
    .stat { background: rgba(0,0,0,.2); border: 1px solid rgba(255,255,255,.15); border-radius: 8px; padding: 8px 14px; text-align: center; }
    .stat-num { font-size: 22px; font-weight: 500; color: #fff; line-height: 1; }
    .stat-label { font-size: 9px; color: var(--rojo-claro); text-transform: uppercase; letter-spacing: .06em; margin-top: 2px; }

    /* TAGS */
    .tags-bar { background: var(--fondo2); padding: 12px 48px; display: flex; gap: 8px; flex-wrap: wrap; border-bottom: 1px solid var(--borde); }
    .tag { font-size: 10px; padding: 4px 12px; border-radius: 20px; font-weight: 500; border: 1px solid; }

    /* DESCRIPCIÓN */
    .desc-bar { padding: 20px 48px; display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; border-bottom: 1px solid var(--borde); background: #fff; }
    .desc-txt { font-size: 13px; color: var(--texto-suave); line-height: 1.6; max-width: 580px; }

    .btn-ingresar {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--rojo); color: #fff;
      padding: 12px 24px; border-radius: 30px;
      font-size: 14px; font-weight: 500; text-decoration: none;
      transition: all .2s; white-space: nowrap;
      box-shadow: 0 4px 16px rgba(153,60,29,.25);
    }
    .btn-ingresar:hover { background: #7A2900; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(153,60,29,.35); }

    /* BODY */
    .body { padding: 24px 48px 40px; background: #fff; }

    .seccion-label {
      font-size: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: .08em;
      margin: 20px 0 12px; display: flex; align-items: center; gap: 10px;
    }
    .seccion-label::after { content: ''; flex: 1; height: 1px; background: var(--borde); }

    .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 10px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }

    .mod-card {
      border-radius: 10px; overflow: hidden; border: 1.5px solid;
      text-decoration: none; display: block;
      transition: transform .15s, box-shadow .15s;
      cursor: pointer; background: #fff;
    }
    .mod-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.08); }

    .mod-top { padding: 8px 12px 5px; display: flex; justify-content: space-between; align-items: center; }
    .mod-etiqueta { font-size: 10px; font-weight: 500; }
    .mod-dot { width: 7px; height: 7px; border-radius: 50%; }
    .mod-nombre { font-size: 12px; font-weight: 500; color: #1a0f0a; padding: 0 12px 4px; line-height: 1.3; }
    .mod-fichas { font-size: 10px; padding: 0 12px 10px; }

    /* FOOTER */
    .footer {
      background: var(--fondo2); padding: 14px 48px;
      display: flex; justify-content: space-between; align-items: center;
      border-top: 1px solid var(--borde); flex-wrap: wrap; gap: 10px;
    }
    .footer-badges { display: flex; gap: 8px; flex-wrap: wrap; }
    .footer-badge { font-size: 9px; padding: 3px 10px; border-radius: 20px; border: 1px solid; font-weight: 500; }
    .footer-txt { font-size: 10px; color: var(--texto-suave); }

    @media (max-width: 900px) {
      .hero { padding: 28px 24px; }
      .hero-left .titulo { font-size: 38px; }
      .tags-bar, .desc-bar, .body, .footer { padding-left: 24px; padding-right: 24px; }
      .grid { grid-template-columns: repeat(2, 1fr); }
      .grid-3 { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .grid { grid-template-columns: 1fr 1fr; }
      .hero-left .titulo { font-size: 30px; }
    }
  </style>
</head>
